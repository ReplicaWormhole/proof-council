# Copy this to smoke/secrets.env and fill in real keys.
# Only the providers invoked by firstproof_smoke_fast are needed;
# the Council uses one model per provider.

# REQUIRED: Author + Critic + Council OpenAI seat.
OPENAI_API_KEY=

# REQUIRED for Council Anthropic seat (sonnet_46).
ANTHROPIC_API_KEY=

# REQUIRED for Council Gemini seat (gemini-3.1-pro).
GOOGLE_API_KEY=

# Optional: tighten per-problem budget further if running on a metered key.
# FIRSTPROOF_BUDGET_USD_PER_QUESTION=2.0
# FIRSTPROOF_MAX_PARALLEL=6
# FIRSTPROOF_N_ROUNDS=2
# FIRSTPROOF_PAGE_LIMIT=8
